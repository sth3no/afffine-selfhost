# =========================================================
# AFFiNE + MCP Agent — Portainer stack environment
# Copy to `.env` (or paste into Portainer's "Environment variables" UI)
# =========================================================

# ---- AFFiNE image ----
# Use `stable` for production, `canary` for latest dev features (required for MCP write ops)
AFFINE_REVISION=stable

# External port where AFFiNE is exposed on the host
PORT=3010

# Public URL users will access. Pick ONE approach:
#
#  (a) Single URL (simplest):
AFFINE_SERVER_EXTERNAL_URL=http://localhost:3010
#
#  (b) Split host + scheme (matches upstream docs; leave URL blank if using this):
# AFFINE_SERVER_HOST=affine.example.com
# AFFINE_SERVER_HTTPS=true
AFFINE_SERVER_HOST=
AFFINE_SERVER_HTTPS=

# ---- Database ----
DB_USERNAME=affine
DB_PASSWORD=change-me-to-a-strong-password
DB_DATABASE=affine

# ---- Mailer (optional — leave blank to disable email features) ----
MAILER_HOST=
MAILER_PORT=
MAILER_USER=
MAILER_PASSWORD=
MAILER_SENDER=

# ---- MCP Agent ----
# Leave these blank on FIRST deploy. After AFFiNE is up:
#   1. Open http://<host>:3010 and create the admin account
#   2. Go to Workspace Settings → Integration → MCP Server → Generate Token
#   3. Copy the workspace ID from the URL (/workspace/<ID>/...)
#   4. Set these two values and redeploy the stack (or just the mcp_agent service)
AFFINE_WORKSPACE_ID=
AFFINE_ACCESS_TOKEN=

# Timezone used by node-cron inside the agent
TZ=UTC

# ---- Cross-stack networking (n8n etc.) ----
# External Docker network shared with other Portainer stacks.
# Create ONCE on the host before deploying this stack:
#   docker network create shared_net
# Then attach your other stacks (n8n, etc.) to the SAME network name.
# From n8n workflows you can then reach AFFiNE at: http://affine:3010
SHARED_NETWORK=shared_net
